    "jose": "^5.3.0",
    "cbor2": "^1.8.0",
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0",
    "nanoid": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  },
  "engines": { "node": ">=20.0.0" }
